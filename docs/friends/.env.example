# OpenClaw 環境變數範本
# 複製此文件到 secrets/.env 並填入真實值

# Claude API（選填 — 冇嘅話查詢指令照用，AI 分析唔可用）
# 取得：console.anthropic.com 或你的 proxy 服務
PROXY_API_KEY=sk-ant-你的key

# Proxy Endpoint（選填，預設官方）
# 如使用 proxy 服務則填入
PROXY_BASE_URL=https://api.anthropic.com

# Voyage AI Embedding（建議填入）
# 免費 200M tokens，取得：dash.voyageai.com
VOYAGE_API_KEY=pa-你的key

# Telegram Bot（選填）
# 取得 TOKEN：Telegram @BotFather
# 取得 CHAT_ID：Telegram @userinfobot
TELEGRAM_BOT_TOKEN=你的token
TELEGRAM_CHAT_ID=你的chat_id

# 此文件不要上傳 GitHub
# 請備份到 iCloud 或 1Password
