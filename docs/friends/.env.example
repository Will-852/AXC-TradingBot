# OpenClaw 環境變數模板
# 複製此文件至 ~/.openclaw/secrets/.env

# ─── 必填 ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ─── 交易平台（二選一）───────────────
# Binance：
BINANCE_API_KEY=xxxxxxxxxxxx
BINANCE_API_SECRET=xxxxxxxxxxxx

# Aster DEX：
# ASTER_API_KEY=xxxxxxxxxxxx

# ─── 可選：Telegram 通知 ─────────────
# TELEGRAM_BOT_TOKEN=xxxxxxxxxxxx
# TELEGRAM_CHAT_ID=xxxxxxxxxxxx
