# MAX_OPEN_POSITIONS = 2
# RISK_PER_TRADE_PCT = 0.01

# --- 掃描設定 ---
# SCAN_INTERVAL_SEC = 300

# --- 幣種（完整覆蓋，唔係 append） ---
# ASTER_SYMBOLS = [
#     "BTCUSDT",
#     "ETHUSDT",
# ]

# --- BB 指標 ---
